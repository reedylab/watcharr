# Watcharr environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# qBittorrent connection
QB_URL=http://localhost:8080/
QB_USERNAME=admin
QB_PASSWORD=
QB_CONTAINER=qbittorrent

# Watchdog settings
CHECK_INTERVAL=60

# Optional: dashboard authentication (disabled when empty)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=changeme

# Python output (recommended for Docker)
PYTHONUNBUFFERED=1
